{
  "name": "agentgate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dashboard": "next dev",
    "typecheck": "tsc --noEmit",
    "setup:api": "rm -rf .venv && python3 -m venv .venv && ./.venv/bin/python -m pip install --upgrade pip && ./.venv/bin/pip install -r api/requirements.txt -e ./sdk",
    "reset:state": "rm -f api/agentgate.db",
    "api": "PYTHONPATH=. ./.venv/bin/uvicorn api.main:app --reload --reload-dir api",
    "demo:agent": "AGENTGATE_DASHBOARD_URL=http://localhost:3000/dashboard ./.venv/bin/python demo-agent/agent.py",
    "test:api": "PYTHONPATH=. ./.venv/bin/python -m unittest discover -s api/tests -p 'test_*.py'",
    "check": "npm run lint && npm run typecheck && npm run build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "typescript": "^5"
  }
}
